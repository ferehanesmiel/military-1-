{
  "entities": {
    "user": {
      "title": "User",
      "description": "System user with role and basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "commander", "officer", "staff"] },
        "rank": { "type": "string" },
        "unitId": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "personnel": {
      "title": "Personnel",
      "description": "Military personnel record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "rank": { "type": "string" },
        "branch": { "type": "string" },
        "department": { "type": "string" },
        "supervisorId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "performanceScore": { "type": "number" },
        "attendance": { "type": "number" },
        "training": { "type": "number" },
        "tasks": { "type": "number" },
        "discipline": { "type": "number" }
      },
      "required": ["name", "rank", "branch", "department"]
    },
    "unit": {
      "title": "Unit",
      "description": "Military unit record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "commanderId": { "type": "string" },
        "requiredPersonnel": { "type": "number" },
        "readinessScore": { "type": "number" }
      },
      "required": ["name"]
    },
    "material": {
      "title": "Material",
      "description": "Logistics and equipment record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "quantity": { "type": "number" },
        "assignedTo": { "type": "string" },
        "condition": { "type": "string", "enum": ["Good", "Damaged", "Needs Maintenance"] },
        "location": { "type": "string" },
        "lastMaintenance": { "type": "string", "format": "date" }
      },
      "required": ["name", "type", "quantity"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "user", "description": "User profiles" },
    "/personnel/{personnelId}": { "schema": "personnel", "description": "Personnel records" },
    "/units/{unitId}": { "schema": "unit", "description": "Unit records" },
    "/materials/{materialId}": { "schema": "material", "description": "Material records" }
  }
}
